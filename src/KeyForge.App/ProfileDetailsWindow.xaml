<Window x:Class="KeyForge.App.ProfileDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Profile Details"
        Height="700"
        Width="520"
        MinHeight="620"
        MinWidth="460"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        Icon="/Assets/KFIcon.png">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource RailBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Image Source="/Assets/KFIcon.png" Width="22" Height="22" Margin="0,0,10,0" />
                    <TextBlock x:Name="WindowTitleText"
                               Text="Profile Details"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click" ToolTip="Minimize" />
                    <Button Content="&#xE922;" Style="{StaticResource TitleBarButton}" Click="MaximizeButton_Click" ToolTip="Maximize" />
                    <Button Content="&#xE8BB;" Style="{StaticResource TitleBarButton}" Click="CloseButton_Click" ToolTip="Close" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelCard}" Margin="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Profile Settings" FontSize="22" FontWeight="Black" />
                    <TextBlock Text="Target, appearance, and activation settings for this profile." Style="{StaticResource MutedText}" Margin="0,3,0,14" />

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="58" Height="58" CornerRadius="8" Background="{DynamicResource PanelAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Image x:Name="ProfileIconImage" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Profile Icon" Style="{StaticResource SectionLabel}" />
                            <TextBlock x:Name="IconPathText" Text="No icon selected" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Profile Name" Style="{StaticResource MutedText}" />
                    <TextBox x:Name="ProfileNameTextBox" TextChanged="ProfileField_Changed" />

                    <TextBlock Text="Mode" Style="{StaticResource MutedText}" />
                    <ComboBox x:Name="ModeComboBox" SelectionChanged="ProfileField_Changed" />

                    <CheckBox x:Name="ProfileEnabledCheckBox"
                              Content="Enabled in active stack"
                              Checked="ProfileField_Changed"
                              Unchecked="ProfileField_Changed" />

                    <Separator Margin="0,16" Background="{DynamicResource BorderBrush}" />

                    <TextBlock Text="Target" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Executable" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                    <TextBox x:Name="TargetExeTextBox" TextChanged="ProfileField_Changed" />
                    <TextBlock Text="Executable Path" Style="{StaticResource MutedText}" />
                    <TextBox x:Name="ExecutablePathTextBox" IsReadOnly="True" />
                    <TextBlock Text="Window Title Match" Style="{StaticResource MutedText}" />
                    <TextBox x:Name="WindowTitleTextBox"
                             TextChanged="ProfileField_Changed"
                             ToolTip="Optional. Leave blank to match every window from the selected executable." />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SelectExeButton"
                                Grid.Column="0"
                                Content="Choose EXE"
                                Click="SelectExeButton_Click"
                                Margin="0,4,6,0" />
                        <Button x:Name="ChooseArtworkButton"
                                Grid.Column="1"
                                Content="Upload Background"
                                Click="ChooseArtworkButton_Click"
                                Margin="6,4,0,0" />
                    </Grid>

                    <TextBlock x:Name="ArtworkPathText" Text="No keyboard background selected" Style="{StaticResource MutedText}" Margin="0,12,0,0" />

                    <Border CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Height="150"
                            Margin="0,10,0,0"
                            Background="#660F141F"
                            ClipToBounds="True">
                        <Grid>
                            <Image x:Name="ArtworkPreviewImage" Stretch="UniformToFill" Opacity="0.8" />
                            <Border Background="#7A07080D" />
                            <TextBlock Text="Keyboard Background"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <Separator Margin="0,16" Background="{DynamicResource BorderBrush}" />
                    <TextBlock x:Name="BindingsCountText" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="StatusText" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
